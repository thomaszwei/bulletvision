# BulletVision — Environment Variables
# Copy this file to .env and fill in values before running.

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/db/bulletvision.db
DATA_DIR=/app/data

# Set to "true" to replay sample images instead of using a real camera.
# Use this for development on non-Pi hardware.
DEMO_MODE=false

# Camera device path (v4l2). Override if using /dev/video1 etc.
CAMERA_DEVICE=/dev/video0

# OpenCV capture backend: V4L2 or PICAMERA2
# Use PICAMERA2 on Raspberry Pi OS with libcamera stack.
# Use V4L2 as fallback (also works on Pi with v4l2-utils installed).
CAMERA_BACKEND=V4L2

# Camera resolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Detection loop target FPS (actual FPS may be lower on low-power hardware)
DETECTION_FPS=3

# ── Detection defaults (all overridable via /api/settings) ───────────────────
DETECTION_MIN_AREA=25
DETECTION_MAX_AREA=1500
DETECTION_CIRCULARITY=0.35
DETECTION_DARKNESS_THRESHOLD=120
DETECTION_CONFIDENCE_THRESHOLD=0.55
DETECTION_ALIGNMENT_ENABLED=false

# ── Scoring defaults ─────────────────────────────────────────────────────────
POINTS_PER_HOLE=10
ZONE_SCORING_ENABLED=false

# ── Security ─────────────────────────────────────────────────────────────────
# A simple token to protect the admin API. Leave empty to disable auth (LAN-only default).
# ADMIN_TOKEN=changeme

# ── Frontend (Vite build-time env vars, prefix VITE_) ────────────────────────
# API base URL used when running Vite dev server outside of Docker.
# In production Docker everything goes through nginx so this is not needed.
VITE_API_BASE_URL=http://localhost:8000
